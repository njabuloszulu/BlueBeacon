generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DispatchCall {
  dispatchCallId String   @id @default(uuid()) @map("dispatch_call_id")
  incidentId     String   @map("incident_id")
  severity       String
  assignedUnit   String?  @map("assigned_unit")
  status         String
  createdAt      DateTime @default(now()) @map("created_at")
}

model UnitPosition {
  unitPositionId String   @id @default(uuid()) @map("unit_position_id")
  unitId         String   @map("unit_id")
  latitude       Decimal
  longitude      Decimal
  recordedAt     DateTime @default(now()) @map("recorded_at")
}
