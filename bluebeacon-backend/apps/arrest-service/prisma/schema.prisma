generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Arrest {
  arrestId           String   @id @default(uuid()) @map("arrest_id")
  suspectFullName    String   @map("suspect_full_name")
  suspectIdNumber    String   @map("suspect_id_number")
  arrestingOfficerId String   @map("arresting_officer_id")
  docketId           String   @map("docket_id")
  arrestLocation     String   @map("arrest_location")
  bailStatus         String   @default("not_applied") @map("bail_status")
  bailAmount         Decimal? @map("bail_amount")
  cellNumber         String   @map("cell_number")
  arrestDatetime     DateTime @map("arrest_datetime")
}
