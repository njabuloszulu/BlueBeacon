generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Docket {
  docketId       String      @id @default(uuid()) @map("docket_id")
  incidentId     String      @map("incident_id")
  leadOfficerId  String      @map("lead_officer_id")
  stationId      String      @map("station_id")
  notes          String?
  status         String
  prosecutorId   String?     @map("prosecutor_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  charges        DocketCharge[]
}

model DocketCharge {
  docketChargeId String @id @default(uuid()) @map("docket_charge_id")
  docketId       String @map("docket_id")
  charge         String
  docket         Docket @relation(fields: [docketId], references: [docketId], onDelete: Cascade)
}
