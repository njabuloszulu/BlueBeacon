generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId      String   @id @default(uuid()) @map("user_id")
  fullName    String   @map("full_name")
  idNumber    String   @unique @map("id_number")
  email       String   @unique
  phone       String
  role        String
  stationId   String?  @map("station_id")
  isVerified  Boolean  @default(false) @map("is_verified")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  sessions    Session[]
  mfaDevices  MfaDevice[]
  auditEvents AuditLoginEvent[]
}

model Session {
  sessionId   String   @id @default(uuid()) @map("session_id")
  userId      String   @map("user_id")
  refreshHash String   @map("refresh_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime @map("expires_at")
  user        User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model MfaDevice {
  mfaDeviceId String   @id @default(uuid()) @map("mfa_device_id")
  userId      String   @map("user_id")
  type        String
  verifiedAt  DateTime? @map("verified_at")
  user        User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model AuditLoginEvent {
  auditLoginEventId String   @id @default(uuid()) @map("audit_login_event_id")
  userId            String?  @map("user_id")
  eventType         String   @map("event_type")
  ipAddress         String?  @map("ip_address")
  createdAt         DateTime @default(now()) @map("created_at")
  user              User?    @relation(fields: [userId], references: [userId], onDelete: SetNull)
}
