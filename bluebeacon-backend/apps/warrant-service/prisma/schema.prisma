generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Warrant {
  warrantId            String   @id @default(uuid()) @map("warrant_id")
  docketId             String   @map("docket_id")
  requestingOfficerId  String   @map("requesting_officer_id")
  warrantType          String   @map("warrant_type")
  targetName           String   @map("target_name")
  targetAddress        String   @map("target_address")
  judgeId              String?  @map("judge_id")
  status               String
  digitalSignature     String?  @map("digital_signature")
  issuedAt             DateTime? @map("issued_at")
  expiresAt            DateTime @map("expires_at")
}
