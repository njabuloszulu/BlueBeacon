generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Incident {
  incidentId         String               @id @default(uuid()) @map("incident_id")
  reporterId         String               @map("reporter_id")
  incidentType       String               @map("incident_type")
  description        String
  locationLat        Decimal              @map("location_lat")
  locationLng        Decimal              @map("location_lng")
  status             String
  assignedOfficerId  String?              @map("assigned_officer_id")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  media              IncidentMedia[]
  statusHistory      IncidentStatusHistory[]
}

model IncidentMedia {
  incidentMediaId String   @id @default(uuid()) @map("incident_media_id")
  incidentId      String   @map("incident_id")
  objectKey       String   @map("object_key")
  mediaType       String   @map("media_type")
  uploadedAt      DateTime @default(now()) @map("uploaded_at")
  incident        Incident @relation(fields: [incidentId], references: [incidentId], onDelete: Cascade)
}

model IncidentStatusHistory {
  incidentStatusHistoryId String   @id @default(uuid()) @map("incident_status_history_id")
  incidentId              String   @map("incident_id")
  fromStatus              String   @map("from_status")
  toStatus                String   @map("to_status")
  changedBy               String   @map("changed_by")
  changedAt               DateTime @default(now()) @map("changed_at")
  incident                Incident @relation(fields: [incidentId], references: [incidentId], onDelete: Cascade)
}
